# --- Runtime ---
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# --- Auth + crypto ---
JWT_SECRET=change-me-in-prod-please-use-32-plus-bytes
APPROVAL_LINK_SECRET=change-me-too-used-for-signed-approval-links
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=replace-with-64-hex-chars-from-crypto-randomBytes-32

# --- CORS ---
CORS_ORIGINS=http://localhost:5173

# --- Database (PostgreSQL) ---
# Either set DATABASE_URL OR the individual DB_* fields below.
# Local Docker (repo root): docker compose up -d  →  user postgres / pass postgres
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=Automation_Meta_Ads
DB_SSL=false

# --- Redis (placeholder, used later for queue) ---
# REDIS_URL=redis://localhost:6379

# --- Meta / Facebook ---
META_API_VERSION=v21.0
META_API_BASE_URL=https://graph.facebook.com
META_APP_ID=
META_APP_SECRET=
# Optional: separate Ads-specific app credentials. If unset, falls back to META_APP_*
META_ADS_APP_ID=
META_ADS_APP_SECRET=
META_ADS_OAUTH_APP_ID=
META_ADS_REDIRECT_URI=http://localhost:5173/oauth/meta-ads/callback
FACEBOOK_REDIRECT_URI=http://localhost:5173/oauth/facebook/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_WEBHOOK_VERIFY_TOKEN=
META_VERIFY_TOKEN=
META_WEBHOOK_SECRET=
# CAPI test event code (copy from Meta Events Manager → Test events tab). Leave blank in production.
META_CAPI_TEST_CODE=

# --- LLM providers ---
ANTHROPIC_API_KEY=         # Claude (script generation, classification, brand fit scoring)
OPENAI_API_KEY=            # GPT-4o-mini (existing campaign generation)

# --- Trend intelligence ---
TAVILY_API_KEY=            # Real-time brand/keyword search (~$5/mo at scale)
PRODUCT_HUNT_TOKEN=        # Product Hunt GraphQL (optional — improves rate limits)
YOUTUBE_API_KEY=           # YouTube Data API v3 — free 10K units/day (console.cloud.google.com)
                           # Enables YouTube Trending ingestion. Wikipedia, HN, Spotify need no key.

# --- Pipeline / Scheduler ---
FRONTEND_URL=http://localhost:5173   # Base URL prepended to approval review links in emails
CRON_INTERVAL_HOURS=6               # How often the background pipeline runs (default: 6)
MIN_BRAND_FIT_SCORE=6               # Min composite score (0-10) to trigger bundle generation

# --- X / Twitter ---
X_BEARER_TOKEN=          # App-only auth — trend ingestion + reading public tweets
X_API_KEY=               # Consumer Key — required for account monitoring (webhooks)
X_API_SECRET=            # Consumer Secret
X_ACCESS_TOKEN=          # Access Token — your app's own X account
X_ACCESS_TOKEN_SECRET=   # Access Token Secret

# --- Voice / TTS ---
ELEVENLABS_API_KEY=
AZURE_TTS_KEY=

# --- AWS (Bedrock, S3, etc.; SDK reads these env names by default) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
# Persist uploads / renders to S3 when true (requires bucket + credentials or IAM role).
USE_S3=false

# --- Shotstack — required to merge multi-scene Creatives (SCENE 1…N in script); Models Lab outputs ~3s per scene
SHOTSTACK_API_KEY=
SHOTSTACK_STAGE_API_KEY=
SHOTSTACK_PRODUCTION_API_KEY=

# --- HeyGen — Creatives script→video: first when configured (not raw pixel T2V).
# Dashboard API key: https://app.heygen.com/home?from=&nav=API
# HeyGen-only (skip Models Lab in Creatives ladder even if MODELS_LAB_API_KEY is set): CREATIVES_USE_MODELS_LAB=false
#
# Option A — v3 Video Agent (recommended): API key only; HeyGen picks presenter/production from your script.
# Quick start: https://developers.heygen.com/docs/quick-start — prompts must state target duration; we derive ~seconds from word count.
# HEYGEN_USE_VIDEO_AGENT=true
# HEYGEN_VIDEO_AGENT_MIN_SECONDS=12
# HEYGEN_VIDEO_AGENT_MAX_SECONDS=60
# HEYGEN_VIDEO_AGENT_ORIENTATION=portrait
# If true, v3 Video Agent is used and HEYGEN_AVATAR_ID / HEYGEN_VOICE_ID are ignored for this app.
# Optional webhook instead of polling: HEYGEN_CALLBACK_URL=https://your.app/heygen/webhook
#
# Option B — v2 Avatar + TTS: fixed avatar_id and voice_id from HeyGen lists/API.
# HEYGEN_AVATAR_ID=
# HEYGEN_VOICE_ID=
#
# HEYGEN_POLL_INTERVAL_MS=4000
# HEYGEN_POLL_MAX_ATTEMPTS=450
# HEYGEN_REQUEST_TIMEOUT_MS=120000
# Optional (avatar v2 only): HEYGEN_BACKGROUND_VIDEO_URL= (MP4 URL) or HEYGEN_USE_STOCK_VIDEO_BACKGROUND=true
HEYGEN_API_KEY=
HEYGEN_USE_VIDEO_AGENT=
HEYGEN_CALLBACK_URL=
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=

# Creatives script→video: set false for HeyGen-only stack (Models Lab ignored for this flow). Default: true when unset.
CREATIVES_USE_MODELS_LAB=

# --- ModelsLab — Creatives script→video when HeyGen is not configured and this key is set (API v6, modelslab.com).
# Single-scene text clips are ~25 frames @ 16fps (~1.6s each); use multiple SCENE blocks + Shotstack merge for longer edits.
# Dashboard: https://modelslab.com/dashboard/api-keys
# Do not set MODELS_LAB_BASE_URL to api.modelslab.com (invalid). Default: https://modelslab.com/api/v6
# MODELS_LAB_API_KEY=
# MODELS_LAB_BASE_URL=https://modelslab.com/api/v6
# MODELS_LAB_MODEL=wan2.2
# MODELS_LAB_ASPECT_RATIO=9:16
# MODELS_LAB_DURATION=5
# Cap how many SCENE blocks to render (default 24)
# MODELS_LAB_MAX_SCENES=24
# HTTP timeout per request (submit + fetch poll), ms — default 300000 (5 min), max 900000
# MODELS_LAB_HTTP_TIMEOUT_MS=300000

# --- Kling AI — Creatives “Generate video from script” uses text-to-video only (requires credits).
# Keys: https://kling.ai/dev
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
# KLING_API_BASE_URL=https://api-singapore.klingai.com
KLING_MODEL=kling-v2-master
KLING_DURATION=5
KLING_ASPECT_RATIO=9:16
KLING_MODE=std
# kling-v2-6 only: KLING_SOUND=on or off

# --- Email ---
RESEND_API_KEY=
EMAIL_FROM=approvals@example.com

# --- Feature flags ---
FEATURE_ADS_ENABLED=true
