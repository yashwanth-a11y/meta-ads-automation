# --- Runtime ---
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# --- Auth + crypto ---
JWT_SECRET=change-me-in-prod-please-use-32-plus-bytes
APPROVAL_LINK_SECRET=change-me-too-used-for-signed-approval-links
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=replace-with-64-hex-chars-from-crypto-randomBytes-32

# --- CORS ---
CORS_ORIGINS=http://localhost:5173

# --- Database (PostgreSQL) ---
# Either set DATABASE_URL OR the individual DB_* fields below.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=Automation_Meta_Ads
DB_SSL=false

# --- Redis (placeholder, used later for queue) ---
# REDIS_URL=redis://localhost:6379

# --- Meta / Facebook ---
META_API_VERSION=v21.0
META_API_BASE_URL=https://graph.facebook.com
META_APP_ID=
META_APP_SECRET=
# Optional: separate Ads-specific app credentials. If unset, falls back to META_APP_*
META_ADS_APP_ID=
META_ADS_APP_SECRET=
META_ADS_OAUTH_APP_ID=
META_ADS_REDIRECT_URI=http://localhost:5173/oauth/meta-ads/callback
FACEBOOK_REDIRECT_URI=http://localhost:5173/oauth/facebook/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_WEBHOOK_VERIFY_TOKEN=
META_VERIFY_TOKEN=
META_WEBHOOK_SECRET=
# CAPI test event code (copy from Meta Events Manager → Test events tab). Leave blank in production.
META_CAPI_TEST_CODE=

# --- LLM providers ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- X / Twitter ---
X_BEARER_TOKEN=

# --- Voice / TTS ---
ELEVENLABS_API_KEY=
AZURE_TTS_KEY=

# --- Email ---
RESEND_API_KEY=
EMAIL_FROM=approvals@example.com

# --- Feature flags ---
FEATURE_ADS_ENABLED=true
