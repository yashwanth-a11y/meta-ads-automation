# ModelsLab API (v6) — text-to-video / image-to-video
# Keys: https://modelslab.com/dashboard/api-keys

# Required
MODELS_LAB_API_KEY=your_models_lab_api_key

# Optional: override base URL (default https://modelslab.com/api/v6). Do not use api.modelslab.com — it does not resolve.
MODELS_LAB_BASE_URL=https://modelslab.com/api/v6

# Optional: model_id for text2video / img2video (e.g. wan2.2, ltx-2.3). Legacy values like kling-v2-master map to wan2.2.
MODELS_LAB_MODEL=wan2.2

MODELS_LAB_DURATION=5
MODELS_LAB_ASPECT_RATIO=9:16
MODELS_LAB_NUM_OUTPUTS=1
