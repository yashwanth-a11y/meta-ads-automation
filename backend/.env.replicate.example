# Replicate — https://replicate.com
#
# Pinned hashes (owner/model:64char) break when a version is removed. Prefer official
# slugs like wan-video/wan-2.5-t2v-fast so Replicate resolves the current version.

REPLICATE_API_KEY=r8_...your_token_here...

# Text-to-video (default: Wan 2.5 T2V Fast — official slug, no hash)
REPLICATE_MODEL=wan-video/wan-2.5-t2v-fast

# Image-to-video (optional). If unset and REPLICATE_MODEL is a Wan *t2v* model, defaults to wan-video/wan-2.5-i2v-fast
# REPLICATE_IMAGE_MODEL=wan-video/wan-2.5-i2v-fast

# Wan 2.5: size as WIDTH*HEIGHT (e.g. 720*1280 portrait, 1280*720 landscape)
# REPLICATE_VIDEO_SIZE=720*1280

# Legacy Zeroscope-style models only: length + fps
REPLICATE_VIDEO_LENGTH=4
REPLICATE_FPS=8
